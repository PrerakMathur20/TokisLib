{
  "name": "/tokens",
  "version": "0.1.0",
  "description": "Design token engine for Tokis — color primitives, semantic scales, spacing, typography, shadows, motion, and CSS variable generation.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/css/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node ../../scripts/stamp-cjs.js && node ../../scripts/copy-tokens-css.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "tokis",
    "design-system",
    "design-tokens",
    "css-variables",
    "custom-properties",
    "theming",
    "tokens",
    "color-system",
    "spacing",
    "typography-scale",
    "shadows",
    "motion",
    "dark-mode",
    "light-mode",
    "typescript"
  ],
  "author": "Tokis Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokis-design/tokis.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://tokis.dev/docs/theming",
  "bugs": {
    "url": "https://github.com/tokis-design/tokis/issues"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
