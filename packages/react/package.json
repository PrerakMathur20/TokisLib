{
  "name": "@tokis/react",
  "version": "1.1.0",
  "description": "React adapter for Tokis — composable, accessible components, hooks, and theming context. Zero runtime CSS.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node ../../scripts/stamp-cjs.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "tokis",
    "design-system",
    "react",
    "react-components",
    "headless",
    "accessible",
    "accessibility",
    "a11y",
    "aria",
    "wcag",
    "components",
    "ui",
    "ui-kit",
    "component-library",
    "dark-mode",
    "theming",
    "typescript",
    "zero-runtime",
    "enterprise",
    "saas"
  ],
  "author": "Tokis Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrerakMathur20/TokisLib.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/PrerakMathur20/TokisLib#readme",
  "bugs": {
    "url": "https://github.com/PrerakMathur20/TokisLib/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@tokis/core": "^1.1.0",
    "@tokis/tokens": "^1.1.0",
    "@tokis/theme": "^1.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@tokis/core": "^1.1.0",
    "@tokis/tokens": "^1.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
