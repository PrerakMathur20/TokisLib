{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "composite": false,
    "paths": {
      "@tokis/core": ["./packages/core/src/index.ts"],
      "@tokis/tokens": ["./packages/tokens/src/index.ts"],
      "@tokis/icons": ["./packages/icons/src/index.ts"]
    }
  },
  "include": [
    "vitest.config.ts",
    "scripts/test-setup.ts",
    "packages/core/src/**/*.ts",
    "packages/react/src/**/*.ts",
    "packages/react/src/**/*.tsx",
    "packages/icons/src/**/*.ts",
    "packages/icons/src/**/*.tsx",
    "packages/tokens/src/**/*.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**"
  ]
}
